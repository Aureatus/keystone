{
  "name": "@aureatus/keystone",
  "version": "0.1.0",
  "description": "Manifest-driven environment tooling for multi-project workspaces",
  "license": "MIT",
  "homepage": "https://github.com/Aureatus/keystone#readme",
  "bugs": {
    "url": "https://github.com/Aureatus/keystone/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aureatus/keystone.git"
  },
  "type": "module",
  "files": [
    "README.md",
    "openapi",
    "src",
    "tsconfig.json"
  ],
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "keystone": "./src/cli.ts"
  },
  "scripts": {
    "fixtures:update": "bun scripts/update-fixtures.ts",
    "openapi:generate": "bun scripts/generate-openapi.ts",
    "openapi:check": "bun scripts/generate-openapi.ts --check",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "smoke": "bun scripts/smoke.ts",
    "check": "bun run typecheck && bun run openapi:check && bun run test && bun run smoke"
  },
  "keywords": [
    "env",
    "dotenv",
    "manifest",
    "tooling"
  ],
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "dotenv": "^17.2.3",
    "portless": "^0.5.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.5"
}
